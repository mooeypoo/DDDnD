# Site URL for OG / SEO meta tags.
# Set this to the canonical production URL (with scheme, no trailing slash)
# to generate absolute URLs in social sharing embeds.
#
# Examples:
#   VITE_SITE_URL=https://dddnd.example.com
#   VITE_SITE_URL=https://my-dddnd.netlify.app
#
# When empty, OG image tags use relative paths (works for dev but some
# social-media crawlers require absolute URLs).
VITE_SITE_URL=
